# API 키 (로컬에서만 사용, .env로 복사 후 값을 채우세요)
# 사용하지 않는 항목은 비워 두거나 삭제해도 됩니다.

# Kakao – https://developers.kakao.com/
ANYMEAL_KAKAO_RESTAPI_KEY=your-kakao-rest-api-key-here

# Naver 지역검색/지도 – https://developers.naver.com/
ANYMEAL_NAVER_CLIENT_ID=your-naver-client-id-here
ANYMEAL_NAVER_CLIENT_SECRET=your-naver-client-secret-here

# Google Places 등 – https://console.cloud.google.com/
ANYMEAL_GOOGLE_API_KEY=your-google-api-key-here
